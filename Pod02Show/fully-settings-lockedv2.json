  "launcherInjectCode": "<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\">\n<title>Splash Screen</title>\n<link rel=\"prefetch\" href=\"file:///data/user/0/de.ozerov.fully/files/welcome2.html\">\n\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml, body {\n  height: 100%;\n  width: 100%;\n  overflow: hidden;\n  background: #000;\n  cursor: pointer;\n}\n\n.splash-container {\n  width: 100vw;\n  height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  position: relative;\n  overflow: hidden;\n}\n\n.splash-video {\n  width: 100vw;\n  height: 100vh;\n  object-fit: cover;\n  display: block;\n}\n\n@media (min-aspect-ratio: 1340/800) {\n  .splash-video {\n    width: calc(100vh * 1340 / 800);\n    height: 100vh;\n  }\n}\n\n@media (max-aspect-ratio: 1340/800) {\n  .splash-video {\n    width: 100vw;\n    height: calc(100vw * 800 / 1340);\n  }\n}\n</style>\n</head>\n\n<body>\n<div class=\"splash-container\">\n  <video class=\"splash-video\" autoplay loop muted playsinline preload=\"metadata\">\n    <source src=\"file:///storage/emulated/0/DCIM/Video20.mp4\" type=\"video/mp4\">\n    Your browser does not support the video tag.\n  </video>\n</div>\n\n<script>\n(function() {\n  const targetUrl = 'file:///data/user/0/de.ozerov.fully/files/welcome2.html';\n  let navigating = false;\n\n  function navigateToTarget(e) {\n    if (navigating) return;\n    navigating = true;\n\n    if (e && e.type === 'touchstart') {\n      e.preventDefault();\n    }\n\n    window.location.replace(targetUrl);\n  }\n\n  document.addEventListener('touchstart', navigateToTarget, { passive: false });\n  document.addEventListener('click', navigateToTarget);\n\n  const video = document.querySelector('.splash-video');\n  if (video) {\n    video.addEventListener('loadeddata', function() {\n      video.play().catch(function(err) {\n        console.log('Video autoplay prevented:', err);\n      });\n    });\n  }\n})();\n</script>\n\n</body>\n</html>\n",
